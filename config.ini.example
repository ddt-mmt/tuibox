[mikrotik]
; Pengaturan untuk koneksi ke router MikroTik
router = 10.0.2.110
port = 21112
user = test-speed
password = speed-test

[netbox]
; Pengaturan untuk koneksi ke NetBox API
url = http://10.28.1.100:8001/api
token = 6a51599f642c2a3baadf8c62f8aa1e8c3fead6b1
; Nama Site di NetBox tempat perangkat ini berada (WAJIB untuk sinkronisasi perangkat)
site = DefaultSite
; Peran perangkat di NetBox (contoh: Router, Switch, Server)
device_role = Router

[sync]
; Pengaturan untuk proses sinkronisasi
; Masukkan prefix yang dipisahkan koma
prefixes = 10.28.0.0/16, 192.168.30.0/24, 192.168.80.0/24
; Apakah ping sweep dijalankan? (true/false)
ping_sweep = false
; Apakah mode auto-sync aktif? (true/false)
auto_sync = true
; Interval sinkronisasi dalam menit
interval_minutes = 10
