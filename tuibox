#!/usr/bin/env python3
import requests
import re
import time
import subprocess
import sys
import ipaddress
import configparser
import os
from datetime import datetime

# Handle Timezone Jakarta
try:
    from zoneinfo import ZoneInfo
    JAKARTA_TZ = ZoneInfo("Asia/Jakarta")
except ImportError:
    from datetime import timezone, timedelta
    JAKARTA_TZ = timezone(timedelta(hours=7))

from rich.console import Console
from rich.panel import Panel
from rich.prompt import Prompt, IntPrompt, Confirm
from rich.progress import Progress, SpinnerColumn, TextColumn, BarColumn, TaskProgressColumn

console = Console()

class TuiBoxSync:
    def __init__(self, config_file="config.ini"):
        self.config_file = config_file
        self.config = configparser.ConfigParser()
        self.router = ""
        self.port = 22
        self.user = ""
        self.password = ""
        self.nb_url = ""
        self.nb_token = ""
        self.site = ""
        self.device_role = "" # New: Default device role for NetBox
        self.prefixes_input = []
        self.headers = {}
        self.ping_sweep = False
        self.auto_sync = False
        self.interval = 10

    def get_now(self):
        return datetime.now(JAKARTA_TZ).strftime('%Y-%m-%d %H:%M:%S')

    def get_short_time(self):
        # Format waktu pendek untuk deskripsi NetBox (Tgl/Bln Jam:Menit)
        return datetime.now(JAKARTA_TZ).strftime('%d/%m %H:%M')

    def extract_value(self, key, text):
        match = re.search(rf'{key}[=:]\s*(?:"([^"]+)"|(\S+))', text, re.IGNORECASE)
        if match: return match.group(1) if match.group(1) else match.group(2)
        return None

    def setup(self):
        console.print(Panel("[bold green]TUIBOX: NetBox IPAM & MikroTik Sync (V7 - DCIM Sync)[/bold green]", expand=False))
        
        # Read config file if it exists
        if os.path.exists(self.config_file):
            console.print(f"[yellow]Membaca konfigurasi dari '{self.config_file}'...[/yellow]")
            self.config.read(self.config_file)
        else:
            console.print(f"[yellow]File '{self.config_file}' tidak ditemukan, masuk ke mode interaktif.[/yellow]")

        # Helper to get config value or prompt user
        def get_config_or_prompt(section, key, prompt_text, default=None, is_password=False, is_int=False, is_bool=False):
            if self.config.has_option(section, key):
                if is_bool:
                    return self.config.getboolean(section, key)
                elif is_int:
                    return self.config.getint(section, key)
                return self.config.get(section, key)
            
            # Fallback to interactive prompt
            if is_bool:
                return Confirm.ask(prompt_text, default=default)
            if is_int:
                return IntPrompt.ask(prompt_text, default=default)
            return Prompt.ask(prompt_text, default=str(default) if default is not None else "", password=is_password)

        # MikroTik Settings
        self.router = get_config_or_prompt('mikrotik', 'router', "Masukkan IP Router MikroTik", default="10.0.2.110")
        self.port = get_config_or_prompt('mikrotik', 'port', "Masukkan Port SSH Router", default=21112, is_int=True)
        self.user = get_config_or_prompt('mikrotik', 'user', "Masukkan Username Router", default="test-speed")
        self.password = get_config_or_prompt('mikrotik', 'password', "Masukkan Password Router", default="speed-test", is_password=True)

        # NetBox Settings
        default_nb = "http://10.28.1.100:8001/api"
        self.nb_url = get_config_or_prompt('netbox', 'url', "Masukkan URL API NetBox", default=default_nb).rstrip('/')
        self.nb_token = get_config_or_prompt('netbox', 'token', "Masukkan API Token NetBox", default="6a51599f642c2a3baadf8c62f8aa1e8c3fead6b1", is_password=True)
        self.site = get_config_or_prompt('netbox', 'site', "Masukkan Nama Site di NetBox", default="DefaultSite")
        self.device_role = get_config_or_prompt('netbox', 'device_role', "Masukkan Peran Perangkat di NetBox (contoh: Router)", default="Router")

        # Sync Settings
        default_prefixes = "10.28.0.0/16, 192.168.30.0/24, 192.168.80.0/24"
        prefix_raw = get_config_or_prompt('sync', 'prefixes', "Masukkan Prefix/Segment (pisahkan koma)", default=default_prefixes)
        self.prefixes_input = [p.strip() for p in prefix_raw.split(',')]
        
        self.ping_sweep = get_config_or_prompt('sync', 'ping_sweep', "Jalankan Ping Sweep?", default=False, is_bool=True)
        self.auto_sync = get_config_or_prompt('sync', 'auto_sync', "Aktifkan Mode Auto-Sync?", default=True, is_bool=True)
        if self.auto_sync:
            self.interval = get_config_or_prompt('sync', 'interval_minutes', "Masukkan Interval Sinkronisasi (Menit)", default=10, is_int=True)

        self.headers = {"Authorization": f"Token {self.nb_token}", "Content-Type": "application/json", "Accept": "application/json"}

    def run_ssh(self, command):
        cmd_str = f'sshpass -p "{self.password}" ssh -p {self.port} -o StrictHostKeyChecking=no -o ConnectTimeout=15 {self.user}@{self.router} "{command}"'
        try:
            result = subprocess.run(cmd_str, shell=True, capture_output=True, text=True, timeout=600)
            return result.stdout if result.returncode == 0 else ""
        except: return ""

    def validate_connection(self):
        with console.status("[bold yellow]Memvalidasi koneksi...[/bold yellow]"):
            try:
                res = requests.get(f"{self.nb_url}/status/", headers=self.headers, timeout=5)
                if res.status_code != 200:
                    console.print(f"[bold red]Gagal terhubung ke NetBox API (Status: {res.status_code})[/bold red]")
                    return False
            except Exception as e:
                console.print(f"[bold red]Gagal terhubung ke NetBox URL: {str(e)}[/bold red]")
                return False

            identity = self.run_ssh("/system identity print")
            if not identity:
                console.print("[bold red]Gagal terhubung ke MikroTik via SSH.[/bold red]")
                return False
            console.print(f"[bold green]Koneksi Berhasil![/bold green] Router: {identity.strip()}")
            return True

    def get_or_create(self, endpoint, params, create_payload):
        """Helper to get an object's ID or create it if it doesn't exist."""
        try:
            url = f"{self.nb_url}{endpoint}"
            res = requests.get(url, headers=self.headers, params=params)
            res.raise_for_status()
            data = res.json()

            if data['count'] > 0:
                return data['results'][0]['id']
            else:
                console.print(f"Membuat entri baru di {endpoint} dengan payload: {create_payload.get('name', create_payload.get('model', ''))}")
                res_create = requests.post(url, headers=self.headers, json=create_payload)
                res_create.raise_for_status()
                return res_create.json()['id']
        except requests.exceptions.RequestException as e:
            console.print(f"[bold red]API Error on {endpoint}: {e}[/bold red]")
            if 'res_create' in locals() and hasattr(res_create, 'text'):
                 console.print(f"[bold red]Payload failed: {create_payload} | Response: {res_create.text}[/bold red]")
            return None

    def sync_device_to_netbox(self):
        with console.status("[bold yellow]Sinkronisasi Perangkat (Router) ke NetBox...[/bold yellow]"):
            # 1. Get Router Info
            identity_raw = self.run_ssh("/system identity print")
            hostname = self.extract_value("name", identity_raw)
            if not hostname:
                console.print("[bold red]Gagal mendapatkan hostname router. Membatalkan sinkronisasi perangkat.[/bold red]")
                return None

            routerboard_raw = self.run_ssh("/system routerboard print")
            serial_number = self.extract_value("serial-number", routerboard_raw)
            model = self.extract_value("model", routerboard_raw)
            if not serial_number or not model:
                console.print("[bold red]Gagal mendapatkan serial-number atau model. Membatalkan sinkronisasi perangkat.[/bold red]")
                return None

            # 2. Ensure Dependencies Exist in NetBox
            manufacturer_id = self.get_or_create(
                endpoint='/dcim/manufacturers/',
                params={'name': 'MikroTik'},
                create_payload={'name': 'MikroTik', 'slug': 'mikrotik'}
            )
            if not manufacturer_id: return None

            slug = re.sub(r'[^a-z0-9-]+', '', self.site.lower().replace('_', '-'))
            site_id = self.get_or_create(
                endpoint='/dcim/sites/',
                params={'name': self.site},
                create_payload={'name': self.site, 'slug': slug}
            )
            if not site_id: return None

            device_type_id = self.get_or_create(
                endpoint='/dcim/device-types/',
                params={'model': model},
                create_payload={'model': model, 'slug': re.sub(r'[^a-z0-9-]+', '', model.lower()), 'manufacturer': manufacturer_id}
            )
            if not device_type_id: return None

            device_role_id = self.get_or_create(
                endpoint='/dcim/device-roles/',
                params={'name': self.device_role},
                create_payload={'name': self.device_role, 'slug': re.sub(r'[^a-z0-9-]+', '', self.device_role.lower())}
            )
            if not device_role_id: return None

            # 3. Get or Create Device
            device_id = self.get_or_create(
                endpoint='/dcim/devices/',
                params={'serial': serial_number},
                create_payload={
                    'name': hostname,
                    'device_type': device_type_id,
                    'role': device_role_id,
                    'site': site_id,
                    'serial': serial_number,
                    'status': 'active'
                }
            )
            
            if device_id:
                console.print(f"Perangkat '{hostname}' (ID: {device_id}) berhasil disinkronkan ke NetBox.")
            
            return device_id

    def sync_interfaces_to_netbox(self, device_id):
        with console.status("[bold yellow]Sinkronisasi Interface ke NetBox...[/bold yellow]"):
            # 1. Get existing interfaces from NetBox for this device
            nb_interfaces = {}
            try:
                url = f"{self.nb_url}/dcim/interfaces/?device_id={device_id}&limit=1000"
                while url:
                    res = requests.get(url, headers=self.headers)
                    res.raise_for_status()
                    for iface in res.json().get('results', []):
                        nb_interfaces[iface['name']] = {
                            'id': iface['id'],
                            'mac_address': iface.get('mac_address', '').upper() if iface.get('mac_address') else None
                        }
                    url = res.json().get('next')
            except Exception as e:
                console.print(f"[bold red]Gagal mengambil data interface dari NetBox: {e}[/bold red]")
                return {}

            # 2. Get interfaces from router
            router_interfaces_raw = self.run_ssh("/interface print detail without-paging")
            
            interfaces_to_create = []
            interfaces_to_update = []

            # Mapping from MikroTik types to NetBox types
            type_map = {
                'ether': '1000base-t', 'sfp-sfpplus': '10gbase-x-sfpp',
                'vlan': 'virtual', 'bridge': 'bridge', 'loopback': 'virtual',
                'bond': 'lag', 'wg': 'virtual', 'eoip': 'virtual'
            }

            for line in router_interfaces_raw.splitlines():
                if " name=" not in line: continue # Skip irrelevant lines
                
                name = self.extract_value("name", line)
                iface_type = self.extract_value("type", line)
                mac = self.extract_value("mac-address", line)
                mac = mac.upper() if mac else None

                if not name: continue

                nb_type = type_map.get(iface_type, 'other')
                
                if name not in nb_interfaces:
                    interfaces_to_create.append({
                        'device': device_id,
                        'name': name,
                        'type': nb_type,
                        'mac_address': mac
                    })
                else: # Interface exists, check for MAC update
                    if mac and nb_interfaces[name]['mac_address'] != mac:
                        interfaces_to_update.append({
                            'id': nb_interfaces[name]['id'],
                            'mac_address': mac
                        })

            # 3. Bulk create and update
            if interfaces_to_create:
                console.print(f"Menciptakan {len(interfaces_to_create)} interface baru...")
                try:
                    res = requests.post(f"{self.nb_url}/dcim/interfaces/", headers=self.headers, json=interfaces_to_create)
                    if res.status_code != 201:
                        console.print(f"[bold red]Gagal bulk create interface: {res.status_code} {res.text}[/bold red]")
                except Exception as e:
                    console.print(f"[bold red]Error bulk create interface: {e}[/bold red]")

            if interfaces_to_update:
                console.print(f"Memperbarui {len(interfaces_to_update)} interface...")
                try:
                    res = requests.patch(f"{self.nb_url}/dcim/interfaces/", headers=self.headers, json=interfaces_to_update)
                    if res.status_code != 200:
                        console.print(f"[bold red]Gagal bulk patch interface: {res.status_code} {res.text}[/bold red]")
                except Exception as e:
                     console.print(f"[bold red]Error bulk patch interface: {e}[/bold red]")
            
            # 4. Re-fetch all interfaces to build a complete map for the next step
            final_interface_map = {}
            try:
                url = f"{self.nb_url}/dcim/interfaces/?device_id={device_id}&limit=1000"
                while url:
                    res = requests.get(url, headers=self.headers)
                    res.raise_for_status()
                    for iface in res.json().get('results', []):
                        final_interface_map[iface['name']] = iface['id']
                    url = res.json().get('next')
            except Exception as e:
                console.print(f"[bold red]Gagal mengambil ulang data interface dari NetBox: {e}[/bold red]")

            return final_interface_map


    def sync_vlans_to_netbox(self):
        with console.status("[bold yellow]Sinkronisasi VLAN ke NetBox (Bulk)...[/bold yellow]"):
            # 1. Get all existing VLANs from NetBox
            existing_nb_vlans = set()
            try:
                url = f"{self.nb_url}/ipam/vlans/?limit=1000"
                while url:
                    res = requests.get(url, headers=self.headers)
                    res.raise_for_status()
                    res_json = res.json()
                    for vlan in res_json.get('results', []):
                        existing_nb_vlans.add(vlan['vid'])
                    url = res_json.get('next')
            except Exception as e:
                console.print(f"[bold red]Gagal mengambil data VLAN dari NetBox: {e}[/bold red]")
                return {}

            # 2. Get all VLANs from router
            vlan_data = {}
            vlans_to_create = []
            vlan_raw = self.run_ssh("/interface vlan print terse without-paging")
            for line in vlan_raw.splitlines():
                name = self.extract_value("name", line)
                vid_str = self.extract_value("vlan-id", line)
                if name and vid_str:
                    vid = int(vid_str)
                    vlan_data[name] = vid
                    # 3. Compare and add to create list
                    if vid not in existing_nb_vlans:
                        vlans_to_create.append({
                            "name": name,
                            "vid": vid,
                            "status": "active",
                            "description": "Auto-created by TUIBOX"
                        })
                        # Add to set to prevent duplicate adds in same run
                        existing_nb_vlans.add(vid)
            
            # 4. Bulk create
            if vlans_to_create:
                console.print(f"Menciptakan {len(vlans_to_create)} VLAN baru di NetBox...")
                try:
                    res = requests.post(f"{self.nb_url}/ipam/vlans/", headers=self.headers, json=vlans_to_create)
                    if res.status_code != 201:
                        console.print(f"[bold red]Gagal bulk create VLAN: {res.status_code} - {res.text}[/bold red]")
                except Exception as e:
                    console.print(f"[bold red]Error bulk create VLAN: {e}[/bold red]")
        
        return vlan_data

    def sync_prefixes_to_netbox(self):
        with console.status("[bold yellow]Menyelaraskan Prefix ke NetBox (Bulk)...[/bold yellow]"):
            # 1. Get all existing prefixes from NetBox
            existing_nb_prefixes = set()
            try:
                url = f"{self.nb_url}/ipam/prefixes/?limit=1000"
                while url:
                    res = requests.get(url, headers=self.headers)
                    res.raise_for_status()
                    res_json = res.json()
                    for prefix in res_json.get('results', []):
                        existing_nb_prefixes.add(prefix['prefix'])
                    url = res_json.get('next')
            except Exception as e:
                console.print(f"[bold red]Gagal mengambil data Prefix dari NetBox: {e}[/bold red]")
                return

            # 2. Compare with user input and collect new ones
            prefixes_to_create = []
            for p_str in self.prefixes_input:
                try:
                    cidr = str(ipaddress.ip_network(p_str, strict=False))
                    if cidr not in existing_nb_prefixes:
                        prefixes_to_create.append({
                            "prefix": cidr,
                            "status": "active",
                            "description": "Auto-created by TUIBOX"
                        })
                        existing_nb_prefixes.add(cidr) # Avoid duplicates in same run
                except ValueError:
                    console.print(f"[bold red]Prefix tidak valid di input: '{p_str}'[/bold red]")
            
            # 3. Bulk create
            if prefixes_to_create:
                console.print(f"Menciptakan {len(prefixes_to_create)} Prefix baru di NetBox...")
                try:
                    res = requests.post(f"{self.nb_url}/ipam/prefixes/", headers=self.headers, json=prefixes_to_create)
                    if res.status_code != 201:
                        console.print(f"[bold red]Gagal bulk create Prefix: {res.status_code} - {res.text}[/bold red]")
                except Exception as e:
                    console.print(f"[bold red]Error bulk create Prefix: {e}[/bold red]")

    def ip_in_prefixes(self, ip_str):
        try:
            ip_obj = ipaddress.ip_address(ip_str)
            for p in self.prefixes_input:
                if ip_obj in ipaddress.ip_network(p, strict=False): return True
        except: pass
        return False

    def ensure_prefixes_exist(self, prefix_list):
        if not prefix_list: return
        with console.status("[bold yellow]Memastikan Parent Prefix tersedia di NetBox...[/bold yellow]"):
            existing_nb_prefixes = set()
            try:
                url = f"{self.nb_url}/ipam/prefixes/?limit=1000"
                while url:
                    res = requests.get(url, headers=self.headers)
                    res.raise_for_status()
                    res_json = res.json()
                    for prefix in res_json.get('results', []):
                        existing_nb_prefixes.add(prefix['prefix'])
                    url = res_json.get('next')
            except Exception as e:
                console.print(f"[bold red]Gagal memvalidasi Prefix: {e}[/bold red]")
                return

            prefixes_to_create = []
            for p_str in prefix_list:
                if p_str not in existing_nb_prefixes:
                    prefixes_to_create.append({
                        "prefix": p_str,
                        "status": "active",
                        "description": "Auto-created by TUIBOX Sync"
                    })
                    existing_nb_prefixes.add(p_str)
            
            if prefixes_to_create:
                console.print(f"Menciptakan {len(prefixes_to_create)} Parent Prefix baru...")
                try:
                    res = requests.post(f"{self.nb_url}/ipam/prefixes/", headers=self.headers, json=prefixes_to_create)
                except: pass

    def scan_and_sync(self):
        waktu_skrg = self.get_now()
        w_pendek = self.get_short_time()
        
        device_id = self.sync_device_to_netbox()
        if not device_id:
            console.print("[bold red]Gagal sinkronisasi device, proses utama dibatalkan.[/bold red]")
            return
        
        interface_map = self.sync_interfaces_to_netbox(device_id)
        
        vlan_map = self.sync_vlans_to_netbox()
        self.sync_prefixes_to_netbox()

        console.print(Panel(f"[bold cyan]Memulai Sinkronisasi IPAM[/bold cyan]\nWaktu: {waktu_skrg}", expand=False))

        ip_to_if = {}
        iface_to_mask = {}
        addr_raw = self.run_ssh("/ip address print terse without-paging")
        for line in addr_raw.splitlines():
            address = self.extract_value("address", line)
            iface = self.extract_value("interface", line)
            if address and iface:
                ip_only = address.split('/')[0]
                mask = address.split('/')[1]
                ip_to_if[ip_only] = iface
                if iface not in iface_to_mask: iface_to_mask[iface] = mask

        if self.ping_sweep:
            with Progress(SpinnerColumn(), TextColumn("[progress.description]{task.description}"), console=console) as progress:
                for p in self.prefixes_input:
                    try:
                        net = ipaddress.ip_network(p, strict=False)
                        subnets = [net] if net.prefixlen >= 24 else list(net.subnets(new_prefix=24))
                        for i in range(0, len(subnets), 5):
                            batch = subnets[i:i+5]
                            cmds = [f":for i from=1 to=254 do={{ /tool ping {str(sub.network_address).rsplit('.', 1)[0]}.$i count=1 timeout=50ms }}" for sub in batch]
                            progress.add_task(description=f"Probing {len(batch)} Subnets...", total=None)
                            self.run_ssh(" ; ".join(cmds))
                    except: continue

        live_devices = {}
        # Tambahkan IP Router sendiri ke live_devices agar tidak ter-deprecate
        for ip, iface in ip_to_if.items():
            if self.ip_in_prefixes(ip):
                live_devices[ip] = {"mac": "STATIC-ROUTER", "src": f"Router-Interface ({iface})", "if": iface}

        with console.status("[bold yellow]Membedah data ARP, DHCP, Neighbor...[/bold yellow]"):
            arp_raw = self.run_ssh("/ip arp print terse without-paging")
            for line in arp_raw.splitlines():
                ip, mac = self.extract_value("address", line), self.extract_value("mac-address", line)
                if ip and mac:
                    mac, if_name = mac.upper(), self.extract_value("interface", line) or "N/A"
                    if self.ip_in_prefixes(ip): live_devices[ip] = {"mac": mac, "src": f"ARP ({if_name})", "if": if_name}

            dhcp_raw = self.run_ssh("/ip dhcp-server lease print terse without-paging")
            for line in dhcp_raw.splitlines():
                ip, mac = self.extract_value("address", line), self.extract_value("mac-address", line)
                if ip and mac:
                    mac, host = mac.upper(), self.extract_value("host-name", line) or "Unknown"
                    if self.ip_in_prefixes(ip):
                        if ip not in live_devices: live_devices[ip] = {"mac": mac, "src": f"DHCP ({host})", "if": ip_to_if.get(ip, "N/A")}
                        else:
                            if "ARP" in live_devices[ip]["src"]: live_devices[ip]["src"] = f"ARP+DHCP ({host})"

            nb_raw = self.run_ssh("/ip neighbor print terse without-paging")
            for line in nb_raw.splitlines():
                ip, mac = self.extract_value("address", line), self.extract_value("mac-address", line)
                if ip and mac:
                    mac, if_name = mac.upper(), self.extract_value("interface", line) or "N/A"
                    if self.ip_in_prefixes(ip) and ip not in live_devices: live_devices[ip] = {"mac": mac, "src": f"Neighbor ({if_name})", "if": if_name}

        with console.status("[bold yellow]Menganalisis perbedaan dengan NetBox...[/bold yellow]"):
            nb_ips = {}
            try:
                url = f"{self.nb_url}/ipam/ip-addresses/?limit=1000"
                while url:
                    res_json = requests.get(url, headers=self.headers).json()
                    for item in res_json.get('results', []):
                        ip_only = item['address'].split('/')[0]
                        if self.ip_in_prefixes(ip_only):
                            nb_ips[ip_only] = {
                                "id": item['id'], 
                                "full_address": item['address'], 
                                "desc": item.get('description', '') or '', 
                                "status": item['status']['value']
                            }
                    url = res_json.get('next')
            except Exception as e:
                console.print(f"[bold red]Gagal mengambil data dari NetBox: {e}[/bold red]")
                return

            ips_to_create = []
            ips_to_update = []
            ips_to_deprecate = []
            seen_in_scan = set()
            required_prefixes = set()

            for ip, data in live_devices.items():
                seen_in_scan.add(ip)
                if_name = data.get('if', 'N/A')
                vlan_info = f"VLAN: {vlan_map.get(if_name, 'None')}"
                base_info = f"MAC: {data['mac']} | {vlan_info} | IF: {if_name} | Src: {data['src']}"
                
                # --- LOGIC TO ASSIGN IP TO INTERFACE ---
                assignment = {}
                if ip in ip_to_if:
                    router_if_name = ip_to_if[ip]
                    router_if_id = interface_map.get(router_if_name)
                    if router_if_id:
                        assignment = {
                            "assigned_object_type": "dcim.interface",
                            "assigned_object_id": router_if_id
                        }
                # --- END LOGIC ---

                # Determine mask
                matched_mask = "24"
                if if_name in iface_to_mask:
                    matched_mask = iface_to_mask[if_name]
                else:
                    for p in self.prefixes_input:
                        if ipaddress.ip_address(ip) in ipaddress.ip_network(p, strict=False):
                            matched_mask = p.split('/')[1]
                            break
                
                full_addr = f"{ip}/{matched_mask}"
                try:
                    network = ipaddress.ip_network(full_addr, strict=False)
                    required_prefixes.add(str(network))
                except: pass

                if ip in nb_ips:
                    current_nb_ip = nb_ips[ip]
                    needs_update = False
                    if current_nb_ip['status'] != 'active': needs_update = True
                    if current_nb_ip['full_address'] != full_addr: needs_update = True
                    if not all(x in current_nb_ip['desc'] for x in [data['mac'], if_name]): needs_update = True

                    if needs_update:
                        final_desc = f"[UP: {w_pendek}] {base_info}"[:200]
                        update_payload = {"id": current_nb_ip['id'], "address": full_addr, "status": "active", "description": final_desc}
                        update_payload.update(assignment)
                        ips_to_update.append(update_payload)
                else:
                    final_desc = f"[NEW: {w_pendek}] {base_info}"[:200]
                    create_payload = {"address": full_addr, "status": "active", "description": final_desc}
                    create_payload.update(assignment)
                    ips_to_create.append(create_payload)

            for ip, data in nb_ips.items():
                if ip not in seen_in_scan and data['status'] == 'active':
                    clean_desc = re.sub(r'^\[.*?\]\s*', '', data['desc'])
                    final_desc = f"[OFF: {w_pendek}] {clean_desc}"[:200]
                    ips_to_deprecate.append({"id": data['id'], "status": "deprecated", "description": final_desc})

        # AUTO-CREATE PREFIXES
        self.ensure_prefixes_exist(list(required_prefixes))

        
        errors = 0
        with Progress(SpinnerColumn(), TextColumn("[progress.description]{task.description}"), BarColumn(), TaskProgressColumn(), console=console) as progress:
            task_create = progress.add_task("[green]Menyiapkan IP baru...", total=1)
            task_update = progress.add_task("[yellow]Menyiapkan update IP...", total=1)
            task_deprecate = progress.add_task("[red]Menyiapkan IP offline...", total=1)

            if ips_to_create:
                progress.update(task_create, description=f"[green]Mengirim {len(ips_to_create)} IP baru...")
                try:
                    res = requests.post(f"{self.nb_url}/ipam/ip-addresses/", headers=self.headers, json=ips_to_create)
                    if res.status_code != 201:
                        console.print(f"[bold red] Gagal bulk create: {res.status_code} - {res.text}[/bold red]")
                        errors += len(ips_to_create)
                except Exception as e:
                    console.print(f"[bold red] Error bulk create: {e}[/bold red]")
                    errors += len(ips_to_create)
            progress.update(task_create, completed=1, description="[green]Selesai membuat IP baru.")

            all_updates = ips_to_update + ips_to_deprecate
            if all_updates:
                progress.update(task_update, description=f"[yellow]Mengirim {len(all_updates)} update...")
                try:
                    res = requests.patch(f"{self.nb_url}/ipam/ip-addresses/", headers=self.headers, json=all_updates)
                    if res.status_code != 200:
                        console.print(f"[bold red] Gagal bulk patch: {res.status_code} - {res.text}[/bold red]")
                        errors += len(all_updates)
                except Exception as e:
                    console.print(f"[bold red] Error bulk patch: {e}[/bold red]")
                    errors += len(all_updates)
            
            progress.update(task_update, completed=1, description="[yellow]Selesai memperbarui IP.")
            progress.update(task_deprecate, completed=1, description="[red]Selesai memproses IP offline.")


        console.print(f"\n[bold green]✔ Sinkronisasi Selesai![/bold green]")
        console.print(f"Total IP Live di Router: [bold cyan]{len(live_devices)}[/bold cyan]")
        console.print(f"IP Baru: [bold green]{len(ips_to_create)}[/bold green] | IP Update: [bold yellow]{len(ips_to_update)}[/bold yellow] | IP Offline: [bold red]{len(ips_to_deprecate)}[/bold red] | Gagal API: [bold red]{errors}[/bold red]")

if __name__ == "__main__":
    sync = TuiBoxSync()
    try:
        sync.setup()
        if sync.validate_connection():
            while True:
                sync.scan_and_sync()
                if not sync.auto_sync: break
                interval_sec = sync.interval * 60
                console.print(f"\n[bold yellow]Menunggu {sync.interval} menit untuk sinkronisasi berikutnya...[/bold yellow]")
                for i in range(interval_sec, 0, -1):
                    if i % 60 == 0 or i <= 5:
                        sys.stdout.write(f"\rSelanjutnya dalam: {i//60}m {i%60}s  ")
                        sys.stdout.flush()
                    time.sleep(1)
                console.print("\n[bold green]Memulai Sinkronisasi Berkala...[/bold green]")
    except KeyboardInterrupt: console.print("\n[bold red]Dibatalkan oleh User.[/bold red]")
    except Exception as e: console.print(f"\n[bold red]Error Fatal:[/bold red] {e}")
